artifacts/
*.vtk
*.vtu
*.pvtu
*.xdmf
*.xmf
*.pvd

# Logs and runtime dumps
*.log

# Local env files
.env
.env.*

# Mesh files
cases/meshes/onera_m6/*.msh

# Large generated meshes (regenerate: python cases/meshes/onera_m6/generate_onera_m6.py)
cases/meshes/onera_m6/*.msh

# M4 wake-free M6 family (same policy; regenerate:
# python cases/meshes/onera_m6_wakefree/generate_onera_m6_wakefree.py)
cases/meshes/onera_m6_wakefree/*.msh

# M5 rounded-tip M6 family (same policy; regenerate:
# python cases/meshes/onera_m6_roundtip/generate_onera_m6_roundtip.py)
cases/meshes/onera_m6_roundtip/*.msh

# M2 wing-body family (same policy; regenerate:
# python cases/meshes/onera_m6_wingbody/generate_onera_m6_wingbody.py)
cases/meshes/onera_m6_wingbody/*.msh

# B9 conforming wing-body family (same policy; regenerate:
# python cases/meshes/onera_m6_wingbody_conforming/generate_onera_m6_wingbody_conforming.py)
cases/meshes/onera_m6_wingbody_conforming/*.msh

# P9 discrimination fine meshes (roadmap P9: fine stays local;
# regenerate: python cases/meshes/naca0012_2.5d/generate_naca0012.py --level fine)
cases/meshes/naca0012_2.5d/fine.msh

# M3 wake-free family: coarse is committed, medium/fine stay local (7.9 MB+;
# regenerate: python cases/meshes/naca0012_wakefree_2.5d/generate_naca0012_wakefree.py)
cases/meshes/naca0012_wakefree_2.5d/medium.msh
cases/meshes/naca0012_wakefree_2.5d/fine.msh

# P5 demo solution caches (regenerable; figures+CSVs are the committed evidence)
cases/demo/p5_onera_m6/results/*.npz

# P9 demo solution caches (same semantics: the fine M6 Newton solve is the
# expensive run-once artifact; figures+CSVs are the committed evidence)
cases/demo/p9_grid_discrimination/results/*.npz

# B6 demo solution caches (the transonic level-set trajectories; figures+CSVs
# are the committed evidence)
cases/demo/b6_transonic/results/*.npz

# B7 demo solution caches (the M6 3D level-set solves + the far-field study;
# figures+CSVs are the committed evidence)
cases/demo/b7_onera_m6/results/*.npz

# tip-edge singularity demo: per-element Mach fields (the subsonic M0.5 probe;
# figure+CSVs are the committed evidence, ~20 min to regenerate)
cases/demo/p13_tip_edge_singularity/results/*.npz

# B8 level-set tip-taper demo: per-element Mach fields (M6 coarse+medium, M0.5;
# figure+CSVs are the committed evidence, ~45 min to regenerate — medium LS is
# ~8 min/solve, sparse-direct LU on the ~67k-dof extended system)
cases/demo/b8_tip_taper_ls/results/*.npz

# B15 LS-Newton-ramp solution cache (the committed evidence is the
# PNG/CSV; regenerate with PYFP3D_TRANSONIC_GATES=1, ~11 min for the M6
# medium M0.84 ramp)
cases/demo/b15_ls_newton_ramp/results/*.npz

# A1 (Track A) solver-bottleneck 3-D leg solution caches (the committed
# evidence is the PNG/CSV; regenerate with PYFP3D_TRANSONIC_GATES=1, ~1 h
# for the M6 medium M0.84 four-method run)
cases/analysis/a1_solver_bottleneck/results/*.npz

# A2 (Track A) TE-Kutta fidelity derived caches (level-set operator products;
# run_a2.py rebuilds them in ~1 min when absent -- PNG/CSV are the evidence)
cases/analysis/a2_te_kutta_fidelity/results/*.npz

# P14 pressure-Kutta demo tier-2 solution caches (committed evidence is the
# PNG/CSV; regenerate with PYFP3D_TRANSONIC_GATES=1 -- the M6 medium M0.84
# pressure ramp is minutes on top of its probe M0.70 seed solve)
cases/demo/p14_pressure_kutta/results/*.npz

# B14 Schur+AMG demo M6-medium A/B solution caches (committed evidence is the
# PNG/CSV; regenerate with PYFP3D_TRANSONIC_GATES=1, ~30-45 min for the two
# M0.84 ramp arms + two M0.5 lifting arms)
cases/demo/b14_schur_precond/results/*.npz

# Reference papers
docs/references

