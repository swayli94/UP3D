# OS files
.DS_Store
Thumbs.db

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Python packaging/build
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Conda local metadata
.conda/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.pyre/

# Jupyter
.ipynb_checkpoints/

# IDE/editor settings
.vscode/
.idea/

# Solver and visualization artifacts
artifacts/
*.vtk
*.vtu
*.pvtu
*.xdmf
*.xmf
*.pvd

# Logs and runtime dumps
*.log

# Local env files
.env
.env.*

# Mesh files
cases/meshes/onera_m6/*.msh

# Large generated meshes (regenerate: python cases/meshes/onera_m6/generate_onera_m6.py)
cases/meshes/onera_m6/*.msh

# M4 wake-free M6 family (same policy; regenerate:
# python cases/meshes/onera_m6_wakefree/generate_onera_m6_wakefree.py)
cases/meshes/onera_m6_wakefree/*.msh

# M5 rounded-tip M6 family (same policy; regenerate:
# python cases/meshes/onera_m6_roundtip/generate_onera_m6_roundtip.py)
cases/meshes/onera_m6_roundtip/*.msh

# M2 wing-body family (same policy; regenerate:
# python cases/meshes/onera_m6_wingbody/generate_onera_m6_wingbody.py)
cases/meshes/onera_m6_wingbody/*.msh

# B9 conforming wing-body family (same policy; regenerate:
# python cases/meshes/onera_m6_wingbody_conforming/generate_onera_m6_wingbody_conforming.py)
cases/meshes/onera_m6_wingbody_conforming/*.msh

# GV3.3 fuselage body-of-revolution family (same policy; regenerate:
# python cases/meshes/fuselage_bor/generate_fuselage_bor.py)
cases/meshes/fuselage_bor/*.msh

# P9 discrimination fine meshes (roadmap P9: fine stays local;
# regenerate: python cases/meshes/naca0012_2.5d/generate_naca0012.py --level fine)
cases/meshes/naca0012_2.5d/fine.msh

# M3 wake-free family: coarse is committed, medium/fine stay local (7.9 MB+;
# regenerate: python cases/meshes/naca0012_wakefree_2.5d/generate_naca0012_wakefree.py)
cases/meshes/naca0012_wakefree_2.5d/medium.msh
cases/meshes/naca0012_wakefree_2.5d/fine.msh

# Result *.npz commit policy (user directive 2026-07-19): commit only SMALL
# npz NEWLY COMPUTED on the kimi branch itself (currently: b25 f1_*, b28 f2_*). npz
# belonging to main-line cases (b23/b24 analysis caches, demo caches) are
# NOT committed -- the user syncs them across worktrees manually. Heavy demo
# field dumps (p13/b8 per-element Mach fields, up to ~125 MB each) must
# never be committed: >100 MB breaks the GitHub push limit.

cases/demo/*/results/*.npz


# Reference papers
docs/references

# Temporary files
temp/

# External tools built from source (not a repo dependency; e.g. XFOIL
# for cases/reference_data/naca0012_viscous_xfoil -- see its README.md)
tools/

# P11 sphere-shell sweep meshes (local caches; the demo regenerates them,
# ~8 min: python cases/demo/p11_curved_walls/run_demo.py). coarse/medium.msh
# stay committed.
cases/meshes/sphere_shell/h05.msh
cases/meshes/sphere_shell/h03.msh
cases/meshes/sphere_shell/h02.msh
cases/meshes/sphere_shell/h03_far10.msh
cases/analysis/b23_junction_discriminator/meshes/*.msh
