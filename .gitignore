build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Conda local metadata
.conda/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.pyre/

# Jupyter
.ipynb_checkpoints/

# IDE/editor settings
.vscode/
.idea/

